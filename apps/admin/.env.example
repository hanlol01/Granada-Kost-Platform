# Granada Kost — Admin frontend env (M11B)
# All variables are validated by packages/domain/env at bootstrap (ADR-FE-006).
# Copy to .env.local for development.

VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_APP_NAME=Granada Kost Admin

# Feature flags (boolean strings: "true" or "false").
VITE_FEATURE_SMARTLOCK_MODE=simulated
VITE_FEATURE_CCTV_ENABLED=false
VITE_FEATURE_BOOKING_ENABLED=false
VITE_FEATURE_CHAT_ENABLED=false
VITE_FEATURE_PUSH_ENABLED=false

# File upload fallback — Admin WhatsApp phone for upload failures (M12C2).
VITE_ADMIN_WHATSAPP_PHONE=6281234567890
