NODE_ENV=development
APP_NAME="Granada Kost API"
API_PREFIX=api/v1
HOST=0.0.0.0
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:8081
LOG_LEVEL=info

JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-characters
JWT_ACCESS_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

DATABASE_URL=postgresql://postgres:hansdevelop@localhost:5432/granada_kost_dev
DB_SSL=false

REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=granada:

UPLOAD_STORAGE_PATH=./uploads
UPLOAD_MAX_FILE_SIZE_MB=5
# Optional. Leave empty/undefined to disable per-property upload quota.
# UPLOAD_PROPERTY_QUOTA_MB=5120

# Smart Lock provider selection & safety gates (M13C; backend-only enforcement).
# Live commands require BOTH SMART_LOCK_PROVIDER=tuya AND SMART_LOCK_LIVE_ENABLED=true,
# and are NOT implemented in M13C (they return LIVE_COMMAND_DISABLED regardless).
SMART_LOCK_PROVIDER=simulated
SMART_LOCK_LIVE_ENABLED=false
SMART_LOCK_COMMAND_TIMEOUT_MS=15000
# Optional unlock rate-limit override (defaults come from smart-lock-rate-limit.helper.ts).
# SMART_LOCK_MAX_UNLOCK_PER_MINUTE=

# Tuya env bootstrap secret source - LOCAL/SITE-TEST ONLY. Placeholders only; never commit real values.
# Production direction remains credential_ref resolution via SmartLockSecretResolutionService.
TUYA_CLIENT_ID=
TUYA_CLIENT_SECRET=
# Region key (sg | us | ueaz | eu | weaz | cn) OR explicit base URL. TUYA_BASE_URL wins when both are set.
TUYA_REGION=
TUYA_BASE_URL=
# TUYA_PROJECT_ID=
# Diagnostic-only device id for local/site-test health checks; never used on production command paths.
# TUYA_DEVICE_ID_TEST=
