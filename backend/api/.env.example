NODE_ENV=development
APP_NAME="Granada Kost API"
API_PREFIX=api/v1
HOST=0.0.0.0
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:8081
LOG_LEVEL=info

JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-characters
JWT_ACCESS_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

DATABASE_URL=postgres://postgres:postgres@localhost:5432/granada_kost
DB_SSL=false

REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=granada:
