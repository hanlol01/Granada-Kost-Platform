{
  "name": "@granada-kost/api",
  "private": true,
  "version": "0.1.0",
  "description": "NestJS backend API foundation for Granada Kost Platform.",
  "scripts": {
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "build": "nest build",
    "auth:hash-password": "tsx src/modules/auth/scripts/hash-password.ts",
    "db:migrate": "tsx src/infrastructure/database/scripts/migrate.ts",
    "db:seed": "tsx src/infrastructure/database/scripts/seed-core.ts",
    "db:seed:dev": "tsx src/infrastructure/database/scripts/seed-core.ts --env=development --with-dev-data",
    "db:seed:prod": "tsx src/infrastructure/database/scripts/seed-core.ts --env=production",
    "billing:validate-workflow": "tsx src/infrastructure/database/scripts/validate-billing-workflow.ts",
    "complaint:validate-workflow": "tsx src/infrastructure/database/scripts/validate-complaint-workflow.ts",
    "vehicle:validate-workflow": "tsx src/infrastructure/database/scripts/validate-vehicle-workflow.ts",
    "notification:validate-workflow": "tsx src/infrastructure/database/scripts/validate-notification-workflow.ts",
    "room-inventory:validate": "tsx src/infrastructure/database/scripts/validate-room-inventory-import.ts",
    "room-inventory:apply": "tsx src/infrastructure/database/scripts/validate-room-inventory-import.ts --apply",
    "smartlock:validate-runtime": "tsx src/infrastructure/database/scripts/validate-smartlock-runtime.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"*.json\" \"*.md\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.json\" \"*.md\""
  },
  "dependencies": {
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/terminus": "^11.0.0",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "file-type": "^22.0.1",
    "ioredis": "^5.6.1",
    "joi": "^17.13.3",
    "nestjs-pino": "^4.4.0",
    "pg": "^8.16.2",
    "pino": "^9.7.0",
    "pino-http": "^10.5.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.3",
    "@types/express": "^5.0.6",
    "@types/node": "^22.15.32",
    "@types/pg": "^8.15.4",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "prettier": "^3.5.3",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1"
  }
}
